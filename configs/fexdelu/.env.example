# Hermes Configuration - Example File
# Copy this to .env and fill in your actual values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Allowed User ID (from Telegram - your chat ID)
TELEGRAM_ALLOWED_USER_ID=your-user-id-here

# OpenWeatherMap API Key
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here
WEATHER_API_KEY=your-openweathermap-api-key-here

# Project Root
PROJECT_ROOT=/home/fede/projects/automations

# opencode CLI
OPENCODE_API_URL=http://localhost:4096

# Ollama (local)
OLLAMA_API_URL=http://localhost:11434

# Tailscale IP (run `tailscale ip -4` to get)
TAILSCALE_IP=unknown